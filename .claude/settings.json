{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(./gradlew*)",
      "Bash(./scripts/*)",
      "Bash(git status)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git branch*)",
      "Bash(git checkout*)",
      "Bash(git restore*)",
      "Bash(git stash*)",
      "Bash(adb devices)",
      "Bash(adb shell pm*)",
      "Bash(adb shell dpm*)",
      "Bash(adb shell dumpsys*)",
      "Bash(adb install*)",
      "Bash(adb uninstall*)",
      "Bash(ktlint*)",
      "Bash(detekt*)",
      "Bash(swift-format*)",
      "Bash(swiftlint*)",
      "Bash(flutter format*)",
      "Bash(npm*)",
      "Bash(node*)",
      "Bash(gh pr list*)",
      "Bash(gh pr view*)",
      "Bash(gh issue list*)",
      "Bash(gh issue view*)",
      "Bash(gh release list*)"
    ],
    "ask": [
      "Bash(git push*)",
      "Bash(git rebase*)",
      "Bash(git reset --hard*)",
      "Bash(adb shell dpm set-device-owner*)",
      "Bash(fastboot*)",
      "Bash(gh pr create*)",
      "Bash(gh pr merge*)",
      "Bash(gh release create*)"
    ],
    "deny": [
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git commit*--no-verify*)",
      "Bash(*BIP39*)",
      "Bash(echo*MNEMONIC*)",
      "Bash(rm -rf /*)"
    ]
  },
  "env": {
    "OPENWARDEN_TEST_MODE": "1"
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "shell": "bash",
            "command": "bash \"$CLAUDE_PROJECT_DIR/scripts/hooks/doc-freshness-stop.sh\"",
            "timeout": 10,
            "statusMessage": "Checking doc-freshness"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "shell": "bash",
            "command": "bash \"$CLAUDE_PROJECT_DIR/scripts/hooks/doc-contradiction-check.sh\"",
            "timeout": 10,
            "statusMessage": "Checking code/doc consistency"
          }
        ]
      }
    ]
  }
}
