<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- #20: the dashboard fetches the child's /state + /usage over the LAN. -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!--
      largeHeap (#155): recovery-key setup runs Argon2id at the ratified 256 MiB memory cost
      (RootKeyDerivation, ADR-033 D2 / CRYPTO.md §2 — must NOT be lowered). BouncyCastle's pure-Java
      Argon2 materialises that working set on the Dalvik heap; the default ~192 MB heap OOM-crashed
      onboarding. largeHeap raises the per-app ceiling so the ratified derivation fits. Derivation also
      runs off the main thread (RecoveryOnboardingViewModel) so it never ANRs.
    -->
    <application
        android:name=".OpenWardenApp"
        android:allowBackup="false"
        android:label="@string/app_name"
        android:largeHeap="true"
        android:networkSecurityConfig="@xml/network_security_config"
        android:supportsRtl="true"
        android:theme="@style/Theme.OpenWarden">

        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>
